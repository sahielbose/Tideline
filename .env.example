# ---------------------------------------------------------------------------
# Tideline environment. Copy to .env.local and fill in as needed.
# The app runs fully with ZERO external keys: leave the optional vars blank and
# the mock adapters + mock LLM take over. Only DATABASE_URL is required.
# ---------------------------------------------------------------------------

# Required: Postgres connection string.
# Local Homebrew/Docker default shown; change user/host as needed.
DATABASE_URL=postgresql://localhost:5432/tideline

# Session signing secret. A dev fallback is used if unset, but set this in prod.
AUTH_SECRET=

# ---- Data adapters -------------------------------------------------------
# Which adapter to use when none is specified: mock | file | sandbox
DATA_ADAPTER_DEFAULT=mock

# ---- LLM (optional) ------------------------------------------------------
# Leave LLM_API_KEY blank to use the deterministic mock provider (no network).
# When set, the Anthropic provider is used.
LLM_API_KEY=
LLM_MODEL_AGENT=claude-sonnet-4-6
LLM_MODEL_CLASSIFIER=claude-haiku-4-5-20251001

# ---- Email (optional) ----------------------------------------------------
# Leave blank to log notifications to the console instead of sending email.
RESEND_API_KEY=
RESEND_FROM=Tideline <alerts@tideline.local>

# ---- Inngest (optional) --------------------------------------------------
# For local dev, run `npm run inngest` (no keys needed). These are for hosted.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Sandbox data sources (optional, Phase 2+) ---------------------------
RECORDS_SANDBOX_KEY=
WEARABLES_SANDBOX_KEY=

# Shared secret for the ingestion webhook (/api/webhooks/ingest). Enforced only
# when set. Demo autologin: set DEMO_AUTOLOGIN=false to require a real login.
INGEST_WEBHOOK_SECRET=
DEMO_AUTOLOGIN=true
